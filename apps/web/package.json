{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --port 3010",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "check-types": "tsc --noEmit",
    "worker": "node --import tsx lib/queue/worker.ts",
    "worker:dev": "node --watch --import tsx lib/queue/worker.ts",
    "generate": "zen generate --schema lib/db/schema.zmodel",
    "db:push": "zen db push --schema lib/db/schema.zmodel",
    "db:migrate:dev": "zen migrate dev --schema lib/db/schema.zmodel",
    "db:migrate:deploy": "zen migrate deploy --schema lib/db/schema.zmodel",
    "db:migrate:status": "zen migrate status --schema lib/db/schema.zmodel",
    "db:migrate:reset": "zen migrate reset --schema lib/db/schema.zmodel",
    "db:migrate:reset:worker": "echo \"import pg from 'pg';const p=new pg.Pool({connectionString:process.env.DATABASE_URL});await p.query('DROP SCHEMA IF EXISTS pgboss CASCADE');console.log('pgboss schema dropped');await p.end()\"",
    "db:seed": "node --import tsx lib/db/seed.ts",
    "db:fresh": "pnpm db:migrate:reset:worker && pnpm db:migrate:reset && pnpm db:push && pnpm db:seed",
    "scrape": "node --import tsx scrapers/run-scrape.ts",
    "postinstall": "zen generate --schema lib/db/schema.zmodel"
  },
  "zenstack": {
    "schema": "lib/db/schema.zmodel"
  },
  "dependencies": {
    "@zenstackhq/orm": "^3.5.6",
    "@zenstackhq/plugin-policy": "^3.5.6",
    "better-auth": "^1.6.0",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.479.0",
    "next": "^16.2.2",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.10.0",
    "string-similarity-js": "^2.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^20.19.39",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@zenstackhq/cli": "^3.5.6",
    "@zenstackhq/schema": "^3.5.6",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.2",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
